---
import ProjectLayout from '../../layouts/ProjectLayout.astro';

const metrics = [
  { value: 'Tysiące', label: 'ofert dziennie', icon: '📊' },
  { value: '24/7', label: 'automatyzacja', icon: '⏰' },
  { value: 'API', label: 'dla zespołów', icon: '🔌' },
  { value: 'Cloud', label: 'wdrożenie', icon: '☁️' },
];

const challenges = [
  {
    title: 'Problem',
    description: 'Potrzeba ręcznego pobierania, analizowania i standaryzowania ogromnych wolumenów danych z ofert pracy była czasochłonna i nieefektywna.',
    icon: '🔴',
  },
  {
    title: 'Rozwiązanie',
    description: 'Zbudowanie w zespole skalowalnego systemu ETL w chmurze (Digital Ocean), wykorzystującego asynchroniczne kolejkowanie (Dramatiq, Redis) do automatycznego pobierania i przetwarzania danych w tle.',
    icon: '🟢',
  },
  {
    title: 'Rezultat',
    description: 'W pełni zautomatyzowany przepływ danych: każdego dnia tysiące ofert są agregowane, ustandaryzowane i udostępniane przez wewnętrzne API, błyskawicznie zasilając inne zespoły.',
    icon: '🏆',
  },
];

const features = [
  'Automatyzacja pobierania i harmonogramowania przetwarzania danych',
  'Asynchroniczne kolejkowanie zadań zapewniające odporność na przeciążenia',
  'Standaryzacja i zaawansowane wzbogacanie pobranych informacji',
  'Udostępnianie przygotowanych danych przez dedykowane REST API',
  'Optymalizacja wydajności i zarządzanie pamięcią workerów',
  'Zautomatyzowane wdrażanie aplikacji (CI/CD) w środowisku chmurowym',
];

const techDetails = [
  { name: 'Backend & API', value: 'Python, FastAPI' },
  { name: 'Kolejkowanie', value: 'Dramatiq, Redis' },
  { name: 'Baza danych', value: 'PostgreSQL' },
  { name: 'Infrastruktura', value: 'Digital Ocean, Docker, MinIO' },
  { name: 'Zarządzanie projektem', value: 'GitHub, Trello' },
  { name: 'Środowisko', value: 'Chmura publiczna' },
  { name: 'Status', value: 'Produkcja' },
];

const roles = [
  'Implementacja modułu pobierania danych z użyciem asynchronicznego kolejkowania',
  'Wdrożenie i wielokrotne aktualizacje aplikacji na Digital Ocean',
  'Diagnoza i rozwiązywanie problemów wydajnościowych (m.in. optymalizacja zużycia RAM przez workerów)',
  'Testowanie i uruchamianie systemu lokalnie przy pomocy Docker i MinIO (emulacja S3)',
  'Analiza i przegląd kodu zespołu (Code Review)',
  'Konfiguracja przepływów CI/CD (GitHub Actions) do automatycznego wdrażania'
];
---

<ProjectLayout
  title="Automatyzacja ETL na rynku pracy — Case Study"
  description="Skalowalny system ETL w chmurze przetwarzający tysiące ofert pracy dziennie i udostępniający je przez API."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-gray-500">
        <li><a href="/ds_ai_portfolio/" class="hover:text-accent transition-colors">Strona główna</a></li>
        <li>/</li>
        <li><a href="/ds_ai_portfolio/#projekty" class="hover:text-accent transition-colors">Projekty</a></li>
        <li>/</li>
        <li class="text-gray-300">Automatyzacja ETL rynku pracy</li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <div class="inline-block bg-accent text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-4 shadow-lg shadow-accent/30">
        Flagship Project
      </div>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">Automatyzacja agregacji i przetwarzania danych z rynku pracy</h1>
      <p class="text-gray-400 text-lg max-w-3xl mb-6">
        Wdrożenie skalowalnego systemu ETL w chmurze — codzienne pobieranie dużych 
        wolumenów danych z zewnętrznego źródła, wzbogacanie, standaryzacja i udostępnianie 
        przez własne API. Projekt realizowany zespołowo.
      </p>
      <div class="flex flex-wrap gap-2">
        {['Python', 'FastAPI', 'Dramatiq', 'Redis', 'PostgreSQL', 'Docker', 'Digital Ocean', 'MinIO','Git'].map((tag) => (
          <span class="px-3 py-1 text-xs bg-accent/10 text-accent-light rounded-md border border-accent/20">
            {tag}
          </span>
        ))}
      </div>
    </div>

    <!-- Metrics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-16">
      {metrics.map((m) => (
        <div class="bg-card border border-gray-800 rounded-xl p-5 text-center">
          <div class="text-3xl mb-2">{m.icon}</div>
          <div class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">
            {m.value}
          </div>
          <p class="text-gray-400 text-sm mt-1">{m.label}</p>
        </div>
      ))}
    </div>

    <!-- Problem / Solution / Result -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Od problemu do rozwiązania</h2>
      <div class="space-y-6">
        {challenges.map((c) => (
          <div class="bg-card border border-gray-800 rounded-xl p-6">
            <div class="flex items-start gap-4">
              <span class="text-2xl flex-shrink-0">{c.icon}</span>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">{c.title}</h3>
                <p class="text-gray-400 leading-relaxed">{c.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Features -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Kluczowe funkcjonalności</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {features.map((f) => (
          <div class="flex items-start gap-3 bg-card border border-gray-800 rounded-lg p-4">
            <span class="text-accent mt-0.5 flex-shrink-0">▸</span>
            <span class="text-gray-300 text-sm">{f}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Tech Details -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Stack technologiczny</h2>
      <div class="bg-card border border-gray-800 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          {techDetails.map((t, i) => (
            <tr class={i % 2 === 0 ? 'bg-card' : 'bg-primary/30'}>
              <td class="px-6 py-3 text-gray-500 font-medium w-1/3">{t.name}</td>
              <td class="px-6 py-3 text-gray-300">{t.value}</td>
            </tr>
          ))}
        </table>
      </div>
    </div>

    <!-- My Role -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Moje zadania w zespole</h2>
      <div class="bg-card border border-gray-800 rounded-xl p-6">
        <ul class="space-y-3">
          {roles.map((r) => (
            <li class="text-gray-300 flex items-start gap-3">
              <span class="text-emerald mt-1 flex-shrink-0">✓</span>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Back -->
    <div class="flex gap-4 items-start">
      <a
        href="/ds_ai_portfolio/#projekty"
        class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors"
      >
        ← Wróć do projektów
      </a>
    </div>
  </div>
</ProjectLayout>