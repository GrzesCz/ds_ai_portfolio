---
import ProjectLayout from '../../layouts/ProjectLayout.astro';

const metrics = [
  { value: 'AI', label: 'rozpoznawanie mowy', icon: '🎙️' },
  { value: 'Vision', label: 'analiza wyników ze zdjęć', icon: '👁️' },
  { value: 'SMS', label: 'automatyczne powiadomienia', icon: '📱' },
  { value: 'R&D', label: 'faza rozwoju', icon: '🏗️' },
];

const challenges = [
  {
    title: 'Geneza',
    description: 'Stworzony przeze mnie wcześniej system dla gabinetu okulistycznego spełniał swoje podstawowe zadania, ale opierał się na starszym stacku technologicznym (PHP/MySQL). Pojawiła się potrzeba unowocześnienia i wdrożenia funkcji sztucznej inteligencji, aby jeszcze bardziej odciążyć lekarzy od pracy manualnej.',
    icon: '💡',
  },
  {
    title: 'Transformacja',
    description: 'Lens-System to gruntowna refaktoryzacja i przebudowa całego oprogramowania od zera. Nowy backend oparty na Pythonie i FastAPI pozwala na płynną integrację z zewnętrznymi API i modelami uczenia maszynowego. Kod generowany jest przy wsparciu narzędzi AI, co drastycznie skraca czas developmentu.',
    icon: '⚙️',
  },
  {
    title: 'Sztuczna Inteligencja w praktyce',
    description: 'Wprowadzamy asystentów AI: zamianę mowy na tekst (lekarz dyktuje diagnozę), analizę wyników badań z aparatury medycznej na podstawie zdjęć (Computer Vision) oraz inteligentny system zarządzania kolejką pacjentów z notyfikacjami SMS.',
    icon: '🤖',
  },
];

const features = [
  'Głosowe uzupełnianie historii chorób (Speech-to-Text)',
  'Automatyczna ekstrakcja danych z obrazów aparatury medycznej (Computer Vision)',
  'Zautomatyzowany system powiadomień SMS dla pacjentów (redukcja odwołanych wizyt)',
  'Nowoczesny, asynchroniczny backend w Pythonie (FastAPI)',
  'Skalowalna architektura mikroserwisowa gotowa na kolejne moduły AI',
];

const techDetails = [
  { name: 'Backend', value: 'Python, FastAPI' },
  { name: 'AI & Machine Learning', value: 'OpenAI API, Computer Vision' },
  { name: 'Integracje', value: 'Twilio (SMS API)' },
  { name: 'Baza Danych', value: 'PostgreSQL, SQLAlchemy' },
  { name: 'Status', value: 'W warsztacie (R&D)' },
];

const roles = [
  'Kompleksowa przebudowa architektury ze starszego języka PHP na nowoczesny Python',
  'Integracja z modelami AI do przetwarzania głosu i obrazu (Speech-to-Text, Vision)',
  'Integracja zewnętrznych API do obsługi komunikacji z pacjentami (SMS)',
  'Wytwarzanie kodu przy pomocy asystentów programistycznych (Agentic AI)',
];
---

<ProjectLayout
  title="Lens System — AI Medical CRM"
  description="Nowoczesny system CRM dla gabinetów okulistycznych rozbudowany o funkcje Sztucznej Inteligencji (Voice-to-Text, Vision, SMS)."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-gray-500">
        <li><a href="/ds_ai_portfolio/" class="hover:text-purple-400 transition-colors">Strona główna</a></li>
        <li>/</li>
        <li><a href="/ds_ai_portfolio/#laboratorium" class="hover:text-purple-400 transition-colors">Laboratorium</a></li>
        <li>/</li>
        <li class="text-gray-300">Lens System</li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <div class="inline-block bg-purple-600 text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-4 shadow-lg shadow-purple-600/30">
        W warsztacie (R&D)
      </div>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">Lens System (AI Medical CRM)</h1>
      <p class="text-gray-400 text-lg max-w-3xl mb-6">
        System CRM nowej generacji dla placówek medycznych. Stanowi ewolucję poprzedniego projektu "Gabinet Okulistyczny", 
        wprowadzając potężne możliwości sztucznej inteligencji. Pozwala lekarzom dyktować diagnozy zamiast je wpisywać 
        oraz automatycznie odczytuje wyniki badań ze zdjęć aparatury medycznej.
      </p>
      <div class="flex flex-wrap gap-2">
        {['Python', 'FastAPI', 'OpenAI', 'Computer Vision', 'SMS API'].map((tag) => (
          <span class="px-3 py-1 text-xs bg-purple-500/10 text-purple-400 rounded-md border border-purple-500/20">
            {tag}
          </span>
        ))}
      </div>
    </div>

    <!-- Metrics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-16">
      {metrics.map((m) => (
        <div class="bg-card border border-gray-800 rounded-xl p-5 text-center">
          <div class="text-3xl mb-2">{m.icon}</div>
          <div class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-purple-200">
            {m.value}
          </div>
          <p class="text-gray-400 text-sm mt-1">{m.label}</p>
        </div>
      ))}
    </div>

    <!-- Zapotrzebowanie / Rozwiązanie / Status -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Wizja i przebudowa</h2>
      <div class="space-y-6">
        {challenges.map((c) => (
          <div class="bg-card border border-gray-800 rounded-xl p-6">
            <div class="flex items-start gap-4">
              <span class="text-2xl flex-shrink-0">{c.icon}</span>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">{c.title}</h3>
                <p class="text-gray-400 leading-relaxed">{c.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Features -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Innowacyjne funkcjonalności AI</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {features.map((f) => (
          <div class="flex items-start gap-3 bg-card border border-gray-800 rounded-lg p-4">
            <span class="text-purple-400 mt-0.5 flex-shrink-0">▸</span>
            <span class="text-gray-300 text-sm">{f}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Tech Details -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Stack technologiczny</h2>
      <div class="bg-card border border-gray-800 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          {techDetails.map((t, i) => (
            <tr class={i % 2 === 0 ? 'bg-card' : 'bg-primary/30'}>
              <td class="px-6 py-3 text-gray-500 font-medium w-1/3">{t.name}</td>
              <td class="px-6 py-3 text-gray-300">{t.value}</td>
            </tr>
          ))}
        </table>
      </div>
    </div>

    <!-- My Role -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Moja rola</h2>
      <div class="bg-card border border-gray-800 rounded-xl p-6">
        <p class="text-gray-400 leading-relaxed mb-4">
          Jako główny inżynier odpowiadam za refaktoryzację systemu oraz wprowadzanie nowatorskich rozwiązań z zakresu AI:
        </p>
        <ul class="space-y-3">
          {roles.map((r) => (
            <li class="text-gray-300 flex items-start gap-3">
              <span class="text-purple-400 mt-1 flex-shrink-0">✓</span>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Back -->
    <div class="flex gap-4 items-start">
      <a
        href="/ds_ai_portfolio/#laboratorium"
        class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors"
      >
        ← Wróć do sekcji Laboratorium
      </a>
    </div>
  </div>
</ProjectLayout>
