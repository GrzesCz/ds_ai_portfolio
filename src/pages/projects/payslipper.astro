---
import ProjectLayout from '../../layouts/ProjectLayout.astro';

const metrics = [
  { value: '100%', label: 'automatyzacji procesu', icon: '⚡' },
  { value: '0', label: 'błędów w przepisywaniu', icon: '🎯' },
  { value: 'PDF', label: 'szyfrowane dokumenty', icon: '🔒' },
  { value: '.exe', label: 'wygodna aplikacja', icon: '💻' },
];

const challenges = [
  {
    title: 'Problem',
    description: 'Proces generowania i wysyłania pasków wynagrodzeń w firmie opierał się na uciążliwej pracy manualnej z plikami Excel. Było to czasochłonne, groziło pomyłkami przy przepisywaniu danych i budziło obawy o poufność informacji (RODO).',
    icon: '🔴',
  },
  {
    title: 'Rozwiązanie',
    description: 'Zaprojektowanie i stworzenie aplikacji z graficznym interfejsem, która pobiera surowe dane z Excela, automatycznie generuje z nich spersonalizowane pliki PDF (zabezpieczone unikalnym hasłem, np. numerem PESEL pracownika) i masowo wysyła je e-mailem.',
    icon: '🟢',
  },
  {
    title: 'Rezultat',
    description: 'Czas realizacji całego procesu skrócił się z kilku godzin do zaledwie kilku minut. Całkowicie wyeliminowano ryzyko pomyłek ludzkich oraz zapewniono najwyższy standard bezpieczeństwa i zgodności z wymogami ochrony danych osobowych.',
    icon: '🏆',
  },
];

const features = [
  'Automatyczne pobieranie i walidacja danych kadrowych z plików Excel',
  'Generowanie pasków wynagrodzeń w formacie PDF',
  'Zabezpieczenie dokumentów hasłem (indywidualnie dla każdego pracownika)',
  'Masowa wysyłka na adresy e-mail z obsługą załączników',
  'Personalizacja treści wiadomości i szczegółowe logowanie zdarzeń (audyt)',
  'Intuicyjny interfejs graficzny dostępny dla osób nietechnicznych (.exe)',
];

const techDetails = [
  { name: 'Język', value: 'Python' },
  { name: 'Przetwarzanie danych', value: 'pandas, openpyxl' },
  { name: 'Generowanie i ochrona PDF', value: 'fpdf, PyPDF2' },
  { name: 'Dystrybucja', value: 'smtplib, MIME (SMTP/IMAP)' },
  { name: 'Interfejs użytkownika', value: 'Flask, HTML, Bootstrap' },
  { name: 'Kompilacja', value: 'PyInstaller (plik .exe)' },
  { name: 'Zarządzanie projektem', value: 'GitHub, Trello' },
];

const roles = [
  'Zaprojektowanie architektury całego rozwiązania',
  'Implementacja logiki przetwarzania danych i generowania bezpiecznych plików PDF',
  'Stworzenie modułu do masowej i spersonalizowanej wysyłki e-maili',
  'Budowa prostego interfejsu graficznego za pomocą HTML i frameworka Flask',
  'Skompilowanie całej aplikacji do łatwego w obsłudze pliku .exe dla działu HR',
];
---

<ProjectLayout
  title="Employee Payslipper — Case Study"
  description="Case study aplikacji Employee Payslipper: automatyzacja generowania i wysyłki pasków wynagrodzeń."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-gray-500">
        <li><a href="/ds_ai_portfolio/" class="hover:text-accent transition-colors">Strona główna</a></li>
        <li>/</li>
        <li><a href="/ds_ai_portfolio/#projekty" class="hover:text-accent transition-colors">Projekty</a></li>
        <li>/</li>
        <li class="text-gray-300">Employee Payslipper</li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <div class="inline-block bg-emerald-500 text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-4 shadow-lg shadow-emerald-500/30">
        Zakończony
      </div>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">Employee Payslipper</h1>
      <p class="text-gray-400 text-lg max-w-3xl mb-6">
        System do kompleksowej obsługi pasków wynagrodzeń zaprojektowany i współtworzony 
        przeze mnie w ramach pracy zespołowej. Aplikacja automatyzuje cały proces — od 
        surowego pliku Excel po bezpieczną wysyłkę e-mailem.
      </p>
      <div class="flex flex-wrap gap-2">
        {['Python', 'Pandas', 'Flask', 'PDF', 'SMTP', 'Bootstrap', 'PyInstaller', 'Git'].map((tag) => (
          <span class="px-3 py-1 text-xs bg-accent/10 text-accent-light rounded-md border border-accent/20">
            {tag}
          </span>
        ))}
      </div>
    </div>

    <!-- Metrics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-16">
      {metrics.map((m) => (
        <div class="bg-card border border-gray-800 rounded-xl p-5 text-center">
          <div class="text-3xl mb-2">{m.icon}</div>
          <div class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">
            {m.value}
          </div>
          <p class="text-gray-400 text-sm mt-1">{m.label}</p>
        </div>
      ))}
    </div>

    <!-- Problem / Solution / Result -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Od problemu do rozwiązania</h2>
      <div class="space-y-6">
        {challenges.map((c) => (
          <div class="bg-card border border-gray-800 rounded-xl p-6">
            <div class="flex items-start gap-4">
              <span class="text-2xl flex-shrink-0">{c.icon}</span>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">{c.title}</h3>
                <p class="text-gray-400 leading-relaxed">{c.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Features -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Kluczowe funkcjonalności</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {features.map((f) => (
          <div class="flex items-start gap-3 bg-card border border-gray-800 rounded-lg p-4">
            <span class="text-accent mt-0.5 flex-shrink-0">▸</span>
            <span class="text-gray-300 text-sm">{f}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Tech Details -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Stack technologiczny</h2>
      <div class="bg-card border border-gray-800 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          {techDetails.map((t, i) => (
            <tr class={i % 2 === 0 ? 'bg-card' : 'bg-primary/30'}>
              <td class="px-6 py-3 text-gray-500 font-medium w-1/3">{t.name}</td>
              <td class="px-6 py-3 text-gray-300">{t.value}</td>
            </tr>
          ))}
        </table>
      </div>
    </div>

    <!-- My Role -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Moja rola w zespole</h2>
      <div class="bg-card border border-gray-800 rounded-xl p-6">
        <ul class="space-y-3">
          {roles.map((r) => (
            <li class="text-gray-300 flex items-start gap-3">
              <span class="text-emerald mt-1 flex-shrink-0">✓</span>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Back -->
    <div class="flex gap-4 items-start">
      <a
        href="/ds_ai_portfolio/#projekty"
        class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors"
      >
        ← Wróć do projektów
      </a>
    </div>
  </div>
</ProjectLayout>