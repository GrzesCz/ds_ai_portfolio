---
import ProjectLayout from '../../layouts/ProjectLayout.astro';

const metrics = [
  { value: '1', label: 'centralne miejsce danych', icon: '🏢' },
  { value: 'Auto', label: 'powiadomienia e-mail', icon: '📧' },
  { value: '100%', label: 'elektroniczne grafiki', icon: '📅' },
  { value: '24/7', label: 'dostęp dla kadr', icon: '👥' },
];

const challenges = [
  {
    title: 'Problem',
    description: 'Rozproszone arkusze Excel i tradycyjne dokumenty papierowe utrudniały poprawne śledzenie czasu pracy, terminów ważności umów czy badań lekarskich, co generowało chaos organizacyjny w dziale kadr.',
    icon: '🔴',
  },
  {
    title: 'Rozwiązanie',
    description: 'Stworzenie od podstaw kompleksowej aplikacji webowej opartej o PHP, Bootstrap i MySQL, która w jednym miejscu centralizuje ewidencję czasu pracy, zarządzanie grafikami, listy płac oraz posiada wbudowany system inteligentnych alertów.',
    icon: '🟢',
  },
  {
    title: 'Rezultat',
    description: 'Znaczące uporządkowanie i przyspieszenie procesów HR. Automatyczne powiadomienia wyeliminowały problem przeterminowanych badań i umów, a tworzenie złożonych grafików zmianowych skrócono do minimum.',
    icon: '🏆',
  },
];

const features = [
  'Zaawansowane tworzenie i zarządzanie grafikami pracowniczymi dla pracy zmianowej',
  'Automatyczne powiadomienia e-mail o zbliżających się kluczowych terminach (BHP, badania, umowy)',
  'Generowanie, archiwizowanie i zarządzanie listami płac',
  'Moduł finansowy: ewidencja faktur i automatyczne przypomnienia o płatnościach',
  'Zarządzanie uprawnieniami i dostępami dla różnych ról użytkowników',
];

const techDetails = [
  { name: 'Język backendu', value: 'PHP' },
  { name: 'Baza danych', value: 'MySQL' },
  { name: 'Frontend', value: 'Bootstrap, CSS, JavaScript' },
  { name: 'Środowisko', value: 'Zewnętrzny serwer komercyjny' },
  { name: 'Status', value: 'Produkcja' },
];

const roles = [
  'Zaprojektowanie struktury i logiki relacyjnej bazy danych (MySQL)',
  'Implementacja kluczowych modułów biznesowych: grafików, list płac, ewidencji czasu pracy oraz modułu ewidencji faktur i monitoringu statusu płatności',
  'Stworzenie systemu automatycznych powiadomień mailowych (CRON/harmonogramowanie)',
  'Zaprojektowanie responsywnego frontendu aplikacji',
  'Skonfigurowanie i wdrożenie gotowego systemu na zewnętrznym serwerze produkcyjnym',
];
---

<ProjectLayout
  title="Ewidencja Pracowników — Case Study"
  description="System (aplikacja webowa) do zarządzania danymi HR: grafiki, listy płac i faktury."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-gray-500">
        <li><a href="/ds_ai_portfolio/" class="hover:text-accent transition-colors">Strona główna</a></li>
        <li>/</li>
        <li><a href="/ds_ai_portfolio/#projekty" class="hover:text-accent transition-colors">Projekty</a></li>
        <li>/</li>
        <li class="text-gray-300">Ewidencja pracowników</li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <div class="inline-block bg-blue-500 text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-4 shadow-lg shadow-blue-500/30">
        Produkcja
      </div>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">Ewidencja pracowników</h1>
      <p class="text-gray-400 text-lg max-w-3xl mb-6">
        Kompleksowa aplikacja webowa stworzona do efektywnego zarządzania kadrą pracowniczą. 
        System eliminuje rozproszone arkusze Excela, agregując w jednym miejscu ewidencję 
        czasu pracy, finanse i niezbędne powiadomienia terminowe.
      </p>
      <div class="flex flex-wrap gap-2">
        {['PHP', 'MySQL', 'Bootstrap', 'CSS', 'JavaScript'].map((tag) => (
          <span class="px-3 py-1 text-xs bg-accent/10 text-accent-light rounded-md border border-accent/20">
            {tag}
          </span>
        ))}
      </div>
    </div>

    <!-- Metrics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-16">
      {metrics.map((m) => (
        <div class="bg-card border border-gray-800 rounded-xl p-5 text-center">
          <div class="text-3xl mb-2">{m.icon}</div>
          <div class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">
            {m.value}
          </div>
          <p class="text-gray-400 text-sm mt-1">{m.label}</p>
        </div>
      ))}
    </div>

    <!-- Problem / Solution / Result -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Od problemu do rozwiązania</h2>
      <div class="space-y-6">
        {challenges.map((c) => (
          <div class="bg-card border border-gray-800 rounded-xl p-6">
            <div class="flex items-start gap-4">
              <span class="text-2xl flex-shrink-0">{c.icon}</span>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">{c.title}</h3>
                <p class="text-gray-400 leading-relaxed">{c.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Features -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Kluczowe funkcjonalności</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {features.map((f) => (
          <div class="flex items-start gap-3 bg-card border border-gray-800 rounded-lg p-4">
            <span class="text-accent mt-0.5 flex-shrink-0">▸</span>
            <span class="text-gray-300 text-sm">{f}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Tech Details -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Stack technologiczny</h2>
      <div class="bg-card border border-gray-800 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          {techDetails.map((t, i) => (
            <tr class={i % 2 === 0 ? 'bg-card' : 'bg-primary/30'}>
              <td class="px-6 py-3 text-gray-500 font-medium w-1/3">{t.name}</td>
              <td class="px-6 py-3 text-gray-300">{t.value}</td>
            </tr>
          ))}
        </table>
      </div>
    </div>

    <!-- My Role -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Moja rola</h2>
      <div class="bg-card border border-gray-800 rounded-xl p-6">
        <p class="text-gray-400 leading-relaxed mb-4">
          Byłem <strong class="text-white">jedynym autorem</strong> rozwiązania, prowadząc projekt przez wszystkie fazy życia oprogramowania:
        </p>
        <ul class="space-y-3">
          {roles.map((r) => (
            <li class="text-gray-300 flex items-start gap-3">
              <span class="text-emerald mt-1 flex-shrink-0">✓</span>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Back -->
    <div class="flex gap-4 items-start">
      <a
        href="/ds_ai_portfolio/#projekty"
        class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors"
      >
        ← Wróć do projektów
      </a>
    </div>
  </div>
</ProjectLayout>