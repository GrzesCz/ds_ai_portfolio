---
import ProjectLayout from '../../layouts/ProjectLayout.astro';

const metrics = [
  { value: '300', label: 'DPI (druk offsetowy)', icon: '🖨️' },
  { value: 'A3', label: 'format gazetki', icon: '📄' },
  { value: 'TIFF', label: 'PDF, JPG — eksport', icon: '📤' },
  { value: 'R&D', label: 'faza rozwoju', icon: '🏗️' },
];

const challenges = [
  {
    title: 'Problem',
    description: 'Właściciel sklepu spożywczego (dla którego wcześniej stworzyłem system kadrowy) potrzebował narzędzia do automatyzacji tworzenia tygodniowych gazetek promocyjnych. Ręczne przygotowywanie plików do druku przez grafika było czasochłonne, kosztowne i podatne na błędy przy częstych zmianach cen.',
    icon: '📋',
  },
  {
    title: 'Rozwiązanie',
    description: 'Budowa backendu FlyerEngine. System pozwoli na tworzenie szablonów gazetek i łatwe przypisywanie do nich produktów z bazy. Głównym zadaniem aplikacji jest automatyczne generowanie ciężkich plików graficznych (TIFF) spełniających rygorystyczne parametry drukarni offsetowej (300 DPI, format A3 ze spadami, profil barw sRGB).',
    icon: '🟢',
  },
  {
    title: 'Obecny status i Vibe Engineering',
    description: 'Projekt jest w trakcie tworzenia przy użyciu innowacyjnej metodyki Vibe Engineering (Agentic AI). Gwarantuje to pełną kontrolę nad procesem tworzenia kodu oraz jego dojrzałe i bezpieczne generowanie. Nacisk kładziony jest na dbanie o najwyższą jakość architektury oraz tworzenie własnych zestawów umiejętności (skills) dla modeli językowych.',
    icon: '🛠️',
  },
];

const completedItems = [
  'Skonfigurowanie bezpiecznego zarządzania środowiskiem deweloperskim (pydantic-settings) z walidacją',
  'Implementacja warstwy dostępu do bazy danych z zarządzaniem pulą połączeń PostgreSQL',
  'Wdrożenie wzorca Composition Root do czystego zarządzania zależnościami (Dependency Injection)',
  'Zaprojektowanie generycznych, reużywalnych modeli danych (m.in. ujednolicona paginacja i obsługa błędów)',
  'Skonfigurowanie kompleksowego środowiska testowego (Pytest) z automatyzacją CI/CD (GitHub Actions)',
  'Przygotowanie pełnej specyfikacji technicznej i założeń architektonicznych pod dalszy rozwój',
  'Opracowanie własnych, dedykowanych szablonów (AI Templates) standaryzujących pracę z Agentami AI',
  'Stworzenie niestandardowych "skills" (np. dla narzędzia Claude Code) gwarantujących wysoką jakość generowanego kodu',
];

const features = [
  'Zarządzanie bazą produktów i ich kategoriami',
  'Tworzenie szablonów gazetek z wydzielonymi miejscami na produkty i automatycznym formatowaniem cen',
  'Szybkie komponowanie nowych gazetek przez przypisywanie produktów do szablonu',
  'Opcja skopiowania układu całej gazetki na kolejny tydzień',
  'Generowanie docelowych plików TIFF (300 DPI, A3) gotowych do wysłania do drukarni',
  'Możliwość wyeksportowania grafiki również do PDF (na e-mail) i JPG (do social mediów)',
  'Przetwarzanie i generowanie grafiki w tle (planowane zadania asynchroniczne)',
];

const techDetails = [
  { name: 'Język', value: 'Python 3.12+' },
  { name: 'Baza danych', value: 'PostgreSQL (pypika + psycopg3, bez ORM)' },
  { name: 'Walidacja i config', value: 'Pydantic, pydantic-settings' },
  { name: 'Testowanie', value: 'Pytest, pytest-mock' },
  { name: 'AI & Code Gen', value: 'Vibe Engineering, Claude Code, Custom Skills' },
  { name: 'Status', value: 'W warsztacie (R&D)' },
  { name: 'Planowane', value: 'FastAPI, Wand (ImageMagick), S3, kolejka zadań' },
];

const roles = [
  'Zebrałem wymagania od klienta i przełożyłem je na konkretną specyfikację techniczną',
  'Zaprojektowałem architekturę aplikacji backendowej (z naciskiem na łatwość testowania i rozwoju)',
  'Zaimplementowałem dostęp do bazy danych PostgreSQL (przy użyciu pypika i psycopg3 zamiast dużego ORMa)',
  'Rozwijałem aplikację zgodnie z podejściem TDD (Test-Driven Development) i skonfigurowałem CI/CD (GitHub Actions)',
  'Nadzorowałem i orkiestrowałem procesy generowania kodu przez sztuczną inteligencję (Vibe Engineering)',
];

const plannedItems = [
  'Zaprojektuję pełne konteksty domenowe (m.in. produkty, kategorie, szablony, generowanie gazetek)',
  'Wystawię skalowalny interfejs REST API w oparciu o framework FastAPI',
  'Opracuję asynchroniczny silnik renderujący pliki TIFF z wykorzystaniem ImageMagick',
  'Wdrożę kolejkę zadań do bezkolizyjnego generowania grafiki wielkoformatowej w tle',
  'Zintegruję system z architekturą chmurową S3 w celu bezpiecznego przechowywania plików wyjściowych',
];
---

<ProjectLayout
  title="FlyerEngine — Laboratorium Innowacji"
  description="Zautomatyzowany system do tworzenia i zarządzania gazetkami promocyjnymi. Generuje natywne pliki TIFF gotowe do druku offsetowego."
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-gray-500">
        <li><a href="/ds_ai_portfolio/" class="hover:text-purple-400 transition-colors">Strona główna</a></li>
        <li>/</li>
        <li><a href="/ds_ai_portfolio/#laboratorium" class="hover:text-purple-400 transition-colors">Laboratorium</a></li>
        <li>/</li>
        <li class="text-gray-300">FlyerEngine</li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <div class="inline-block bg-purple-600 text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider mb-4 shadow-lg shadow-purple-600/30">
        W warsztacie (R&D)
      </div>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">FlyerEngine</h1>
      <p class="text-gray-400 text-lg max-w-3xl mb-6">
        Dedykowany silnik backendowy do skalowalnej automatyzacji składu DTP. Narzędzie, które stworzyłem jako odpowiedź na realne potrzeby branży retail, 
        pozwala na zautomatyzowane budowanie gazetek promocyjnych z wykorzystaniem elastycznych szablonów i bezbłędnie generuje ciężkie pliki graficzne 
        wymagane przez drukarnie offsetowe. Projekt tworzony zgodnie z rygorystycznymi standardami metodyki Vibe Engineering.
      </p>
      <div class="flex flex-wrap gap-2">
        {['Python', 'PostgreSQL', 'Vibe Engineering', 'Agentic AI', 'Pytest'].map((tag) => (
          <span class="px-3 py-1 text-xs bg-purple-500/10 text-purple-400 rounded-md border border-purple-500/20">
            {tag}
          </span>
        ))}
      </div>
    </div>

    <!-- Metrics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-16">
      {metrics.map((m) => (
        <div class="bg-card border border-gray-800 rounded-xl p-5 text-center">
          <div class="text-3xl mb-2">{m.icon}</div>
          <div class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-purple-200">
            {m.value}
          </div>
          <p class="text-gray-400 text-sm mt-1">{m.label}</p>
        </div>
      ))}
    </div>

    <!-- Zapotrzebowanie / Rozwiązanie / Status -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Od zapotrzebowania do rozwiązania</h2>
      <div class="space-y-6">
        {challenges.map((c) => (
          <div class="bg-card border border-gray-800 rounded-xl p-6">
            <div class="flex items-start gap-4">
              <span class="text-2xl flex-shrink-0">{c.icon}</span>
              <div>
                <h3 class="text-white font-bold text-lg mb-2">{c.title}</h3>
                <p class="text-gray-400 leading-relaxed">{c.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Co zrobiłem -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Co zrobiłem</h2>
      <div class="space-y-3">
        {completedItems.map((item) => (
          <div class="flex items-start gap-3 bg-card border border-gray-800 rounded-lg p-4">
            <span class="text-emerald-400 mt-0.5 flex-shrink-0">✓</span>
            <span class="text-gray-300 text-sm">{item}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Co jest w planach -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Co jest w planach</h2>
      <div class="space-y-3">
        {plannedItems.map((item) => (
          <div class="flex items-start gap-3 bg-card border border-gray-800 rounded-lg p-4">
            <span class="text-purple-400 mt-0.5 flex-shrink-0">▸</span>
            <span class="text-gray-300 text-sm">{item}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Features -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Kluczowe funkcjonalności (docelowe)</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {features.map((f) => (
          <div class="flex items-start gap-3 bg-card border border-gray-800 rounded-lg p-4">
            <span class="text-purple-400 mt-0.5 flex-shrink-0">▸</span>
            <span class="text-gray-300 text-sm">{f}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Tech Details -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Stack technologiczny</h2>
      <div class="bg-card border border-gray-800 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          {techDetails.map((t, i) => (
            <tr class={i % 2 === 0 ? 'bg-card' : 'bg-primary/30'}>
              <td class="px-6 py-3 text-gray-500 font-medium w-1/3">{t.name}</td>
              <td class="px-6 py-3 text-gray-300">{t.value}</td>
            </tr>
          ))}
        </table>
      </div>
    </div>

    <!-- My Role -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold text-white mb-6">Moja rola</h2>
      <div class="bg-card border border-gray-800 rounded-xl p-6">
        <p class="text-gray-400 leading-relaxed mb-4">
          Odpowiadam za cały projekt — od zebrania wymagań od klienta po pełną implementację backendu. Wykorzystuję zaawansowane wzorce projektowe (m.in. z zakresu Domain-Driven Design i czystej architektury):
        </p>
        <ul class="space-y-3">
          {roles.map((r) => (
            <li class="text-gray-300 flex items-start gap-3">
              <span class="text-purple-400 mt-1 flex-shrink-0">✓</span>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Back -->
    <div class="flex gap-4 items-start">
      <a
        href="/ds_ai_portfolio/#laboratorium"
        class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors"
      >
        ← Wróć do sekcji Laboratorium
      </a>
    </div>
  </div>
</ProjectLayout>