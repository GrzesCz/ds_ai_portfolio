---
const skillGroups = [
  {
    title: 'Języki & Bazy danych',
    skills: ['Python', 'SQL', 'PostgreSQL', 'MySQL', 'HTML/CSS'],
    icon: '💻'
  },
  {
    title: 'Biblioteki & Frameworki',
    skills: ['Pandas', 'FastAPI', 'Pydantic','NumPy',  'Astro', 'Flask', 'Pytest', 'Streamlit','Bootstrap'],
    icon: '📦'
  },
  {
    title: 'BI & Raportowanie',
    skills: ['Power BI', 'Excel (zaawansowany)', 'ETL Pipelines', 'SharePoint', 'Data Visualization'],
    icon: '📊'
  },
  {
    title: 'AI, DevOps & Narzędzia',
    skills: ['Machine Learning', 'LLM / AI Agents', 'MCP (Model Context Protocol)', 'OpenAI API', 'Docker', 'Digital Ocean', 'Git & GitHub', 'Redis', 'Dramatiq'],
    icon: '⚙️'
  },
];
---

<section id="umiejetnosci" class="py-20">
  <div class="max-w-6xl mx-auto px-4">
    <div class="animate-on-scroll">
      <h2 class="text-3xl font-bold text-white mb-2">Umiejętności</h2>
      <div class="w-20 h-1 bg-accent rounded mb-8"></div>
      <p class="text-gray-400 max-w-2xl mb-12">
        Technologie, narzędzia i rozwiązania chmurowe, z którymi pracuję na co dzień, budując systemy danych i automatyzacje.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {skillGroups.map((group, gi) => (
        <div
          class="animate-on-scroll bg-card border border-gray-800 rounded-2xl p-8 hover:border-accent/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent/5"
          style={`transition-delay: ${gi * 100}ms`}
        >
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-xl bg-primary border border-gray-800 flex items-center justify-center text-2xl shadow-inner">
              {group.icon}
            </div>
            <h3 class="text-white font-bold text-xl">{group.title}</h3>
          </div>
          
          <div class="flex flex-wrap gap-2.5">
            {group.skills.map((skill) => (
              <span class="px-4 py-2 bg-primary text-gray-300 text-sm font-medium rounded-lg border border-gray-800 hover:border-accent/50 hover:text-white hover:bg-accent/5 transition-all cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>