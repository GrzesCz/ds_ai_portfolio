---
const skillGroups = [
  {
    title: 'Języki programowania',
    skills: [
      { name: 'Python', level: 90 },
      { name: 'SQL', level: 85 },
      { name: 'MySQL', level: 80 },
      { name: 'PostgreSQL', level: 75 },
    ],
  },
  {
    title: 'Biblioteki & Frameworki',
    skills: [
      { name: 'Pandas / NumPy', level: 90 },
      { name: 'FastAPI', level: 80 },
      { name: 'PySpark', level: 65 },
      { name: 'Pytest', level: 70 },
    ],
  },
  {
    title: 'BI & Raportowanie',
    skills: [
      { name: 'Power BI', level: 90 },
      { name: 'Excel (zaawansowany)', level: 95 },
      { name: 'ETL Pipelines', level: 80 },
      { name: 'SharePoint', level: 75 },
    ],
  },
  {
    title: 'AI & Narzędzia',
    skills: [
      { name: 'Machine Learning', level: 70 },
      { name: 'LLM / AI Agents', level: 65 },
      { name: 'Docker', level: 65 },
      { name: 'Git & GitHub', level: 75 },
    ],
  },
];
---

<section id="umiejetnosci" class="py-20">
  <div class="max-w-6xl mx-auto px-4">
    <div class="animate-on-scroll">
      <h2 class="text-3xl font-bold text-white mb-2">Umiejętności</h2>
      <div class="w-20 h-1 bg-accent rounded mb-8"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {skillGroups.map((group, gi) => (
        <div
          class="animate-on-scroll bg-card border border-gray-800 rounded-xl p-6"
          style={`transition-delay: ${gi * 100}ms`}
        >
          <h3 class="text-white font-semibold text-lg mb-5">{group.title}</h3>
          <div class="space-y-4">
            {group.skills.map((skill) => (
              <div>
                <div class="flex justify-between text-sm mb-1">
                  <span class="text-gray-300">{skill.name}</span>
                  <span class="text-gray-500">{skill.level}%</span>
                </div>
                <div class="w-full bg-gray-800 rounded-full h-2">
                  <div
                    class="h-2 rounded-full bg-gradient-to-r from-accent to-accent-light transition-all duration-1000"
                    style={`width: ${skill.level}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>