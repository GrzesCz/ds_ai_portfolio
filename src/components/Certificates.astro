---
import { certificates } from '../data/certificates';
---

<section id="certyfikaty" class="py-20 bg-card/30">
  <div class="max-w-6xl mx-auto px-4">
    <div class="animate-on-scroll text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-2">Certyfikaty & Ciągły rozwój</h2>
      <div class="w-20 h-1 bg-accent rounded mx-auto mb-4"></div>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Systematycznie poszerzam wiedzę i umiejętności, podążając za najnowszymi trendami w Data Science i AI.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {certificates.map((cert, i) => (
        <div
          class="animate-on-scroll bg-card border border-gray-800 rounded-xl p-5 hover:border-accent/50 transition-all duration-300 hover:-translate-y-1"
          style={`transition-delay: ${i * 75}ms`}
        >
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center text-accent">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-white font-semibold text-sm leading-tight mb-1">
                {cert.name}
              </h3>
              <p class="text-gray-500 text-xs">{cert.institution}</p>
              <p class="text-accent text-xs mt-1">{cert.date}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>