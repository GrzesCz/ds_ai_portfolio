---
import { certificates } from '../data/certificates';
---

<section id="certyfikaty" class="py-20 bg-card/30">
  <div class="max-w-6xl mx-auto px-4">
    <div class="animate-on-scroll text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-2">Certyfikaty & Ciągły rozwój</h2>
      <div class="w-20 h-1 bg-accent rounded mx-auto mb-4"></div>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Systematycznie poszerzam wiedzę i umiejętności, podążając za najnowszymi trendami w Data Science i AI.
      </p>
    </div>

    <!-- Zakończone -->
        <div class="animate-on-scroll flex items-center justify-center gap-3 mb-8">
          <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center text-accent text-xl">
            🏆
          </div>
          <h3 class="text-2xl font-bold text-white">Ukończone kursy</h3>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">
          {certificates.map((cert, i) => (
            <div
              class="animate-on-scroll bg-card border border-gray-800 rounded-xl p-5 hover:border-accent/50 transition-all duration-300 hover:-translate-y-1"
              style={`transition-delay: ${i * 75}ms`}
            >
              <div class="flex items-start gap-3">
                <div class="flex-shrink-0 w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center overflow-hidden">
                  {cert.logo ? (
                    <img src={cert.logo} alt={`Logo ${cert.institution}`} class="w-8 h-8 object-contain" />
                  ) : (
                    <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                    </svg>
                  )}
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-white font-semibold text-sm leading-tight mb-1">
                    {cert.name}
                  </h3>
                  <p class="text-gray-500 text-xs">{cert.institution}</p>
                  <p class="text-accent text-xs mt-1">{cert.date}</p>
                  {cert.skills && cert.skills.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-2">
                      {cert.skills.map((skill) => (
                        <span class="px-2 py-0.5 text-xs bg-primary text-gray-400 rounded border border-gray-700">{skill}</span>
                      ))}
                    </div>
                  )}
                  {(cert.courseUrl || cert.certificateUrl || cert.url) && (
                    <div class="flex flex-wrap gap-3 mt-2">
                      {cert.courseUrl && (
                        <a
                          href={cert.courseUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1.5 text-xs text-accent hover:text-accent-light transition-colors"
                        >
                          Zobacz kurs
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                      )}
                      {cert.certificateUrl && (
                        <a
                          href={cert.certificateUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1.5 text-xs text-accent hover:text-accent-light transition-colors"
                        >
                          Certyfikat
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                      )}
                      {cert.url && !cert.courseUrl && !cert.certificateUrl && (
                        <a
                          href={cert.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1.5 text-xs text-accent hover:text-accent-light transition-colors"
                        >
                          Certyfikat
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                      )}
                    </div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

    <!-- Pasek rozdzielający -->
    <div class="w-full h-px bg-gradient-to-r from-transparent via-gray-800 to-transparent mb-16"></div>


        <!-- Kursy w trakcie realizacji -->
    <div class="animate-on-scroll mb-16">
      <div class="flex items-center justify-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-lg bg-emerald/10 flex items-center justify-center text-emerald text-xl">
          🚀
        </div>
        <h3 class="text-2xl font-bold text-white">Kursy w trakcie realizacji</h3>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <!-- Kurs 1: Agentic AI -->
        <div class="flex flex-col bg-card border border-gray-800 rounded-xl p-6 relative overflow-hidden group hover:border-emerald/50 transition-colors">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-emerald to-emerald/20"></div>
          <h4 class="text-white font-semibold text-lg mb-2 pl-2">The Complete Agentic AI Engineering Course</h4>
          <p class="flex-1 text-gray-400 text-sm leading-relaxed mb-6 pl-2">
            Zaawansowane tworzenie agentów AI, praca z LLM i wykorzystanie frameworków ułatwiających budowę autonomicznych systemów.
          </p>
          <div class="flex items-center justify-between pl-2 mt-auto">
            <span class="text-xs font-semibold text-emerald bg-emerald/10 px-3 py-1 rounded-full border border-emerald/20">W toku</span>
            <a href="https://www.udemy.com/course/the-complete-agentic-ai-engineering-course/" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent hover:text-accent-light transition-colors inline-flex items-center gap-1.5">
              Zobacz kurs
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Kurs 2: imprv.ai / Twórz i Sprzedawaj Agentów AI -->
        <div class="flex flex-col bg-card border border-gray-800 rounded-xl p-6 relative overflow-hidden group hover:border-emerald/50 transition-colors">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-emerald to-emerald/20"></div>
          <h4 class="text-white font-semibold text-lg mb-2 pl-2">Twórz i Sprzedawaj Agentów AI od ZERA (imprv.ai)</h4>
          <p class="flex-1 text-gray-400 text-sm leading-relaxed mb-6 pl-2">
            Praktyczny kurs tworzenia autonomicznych Agentów AI z wykorzystaniem platformy <strong>n8n</strong>. Budowa wyspecjalizowanych asystentów do konkretnych ról biznesowych (m.in. księgowa, marketingowiec, asystent nauczyciela). 
            <br/><span class="text-emerald/80 text-xs mt-2 block">Obecny etap: Moduł 8 (Budowa własnego Agenta AI)</span>
          </p>
          <div class="flex items-center justify-between pl-2 mt-auto">
            <span class="text-xs font-semibold text-emerald bg-emerald/10 px-3 py-1 rounded-full border border-emerald/20">W toku</span>
 
          </div>
        </div>
      </div>
    </div>

    
</section>