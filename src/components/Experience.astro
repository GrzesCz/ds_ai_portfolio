---
import { experience } from '../data/experience';
---

<section id="doswiadczenie" class="py-20">
  <div class="max-w-6xl mx-auto px-4">
    <div class="animate-on-scroll">
      <h2 class="text-3xl font-bold text-white mb-2">Doświadczenie zawodowe</h2>
      <div class="w-20 h-1 bg-accent rounded mb-12"></div>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 md:left-8 top-0 bottom-0 w-0.5 bg-gray-800"></div>

      <div class="space-y-12">
        {experience.map((entry) => (
          <div class="animate-on-scroll">
            <!-- Company header -->
            <div class="relative flex items-center gap-4 mb-6 pl-12 md:pl-20">
              <div class="absolute left-2.5 md:left-6.5 w-3 h-3 bg-accent rounded-full border-2 border-primary z-10" style="margin-left: -1px;"></div>
              <h3 class="text-xl font-bold text-white">{entry.company}</h3>
            </div>

            <!-- Positions -->
            <div class="space-y-4 pl-12 md:pl-20">
              {entry.positions.map((pos) => (
                <div class="relative bg-card border border-gray-800 rounded-lg p-5 hover:border-gray-700 transition-colors">
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-2">
                    <h4 class="text-white font-semibold">{pos.title}</h4>
                    <span class="text-accent text-sm font-medium whitespace-nowrap">{pos.period}</span>
                  </div>

                  {pos.description && (
                    <ul class="space-y-1.5 mt-3">
                      {pos.description.map((item) => (
                        <li class="text-gray-400 text-sm flex items-start gap-2">
                          <span class="text-accent mt-1 flex-shrink-0">▸</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>