---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div class="animate-on-scroll group bg-card border border-gray-800 rounded-xl overflow-hidden hover:border-accent/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent/5 flex flex-col">
  {project.flagship && (
    <div class="bg-gradient-to-r from-accent to-emerald text-white text-xs font-bold px-4 py-1.5 text-center uppercase tracking-wider">
      Flagship Project
    </div>
  )}

  <div class="p-6 flex flex-col flex-1">
    <h3 class="text-xl font-bold text-white mb-2 group-hover:text-accent transition-colors">
      {project.title}
    </h3>

    <p class="text-gray-400 text-sm leading-relaxed mb-4 flex-1">
      {project.description}
    </p>

    {project.impact && (
      <p class="text-emerald text-xs mb-4 leading-relaxed">
        💡 {project.impact}
      </p>
    )}

    <div class="flex flex-wrap gap-2 mb-4">
      {project.stack.map((tech) => (
        <span class="px-2.5 py-1 text-xs bg-accent/10 text-accent-light rounded-md border border-accent/20">
          {tech}
        </span>
      ))}
    </div>

    {(project.status || project.date) && (
      <div class="text-xs text-gray-500 mb-4 space-y-1">
        {project.status && <p>{project.status.includes('warsztacie') ? '🔬' : '📦'} {project.status}</p>}
        {project.date && <p set:html={`📅 ${project.date.replace(/\(planowany.*?\)/, '<span class="text-red-400">$&</span>')}`}></p>}
      </div>
    )}

    <div class="flex gap-3 mt-auto pt-2">
      {project.page && (
        <a
          href={project.page}
          class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent hover:text-accent-light transition-colors"
        >
          Zobacz szczegóły →
        </a>
      )}
    </div>
  </div>
</div>