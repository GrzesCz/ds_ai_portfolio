---
---

<section class="min-h-screen flex items-center relative overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-indigo-950/30"></div>
  <div class="absolute top-1/4 -right-32 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-1/4 -left-32 w-96 h-96 bg-emerald/5 rounded-full blur-3xl"></div>

  <div class="relative max-w-6xl mx-auto px-4 py-20 w-full">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12 lg:gap-16">
      <!-- Text -->
      <div class="w-full lg:w-3/5 text-center lg:text-left">
        <p class="text-accent font-medium mb-3 text-sm tracking-wider uppercase">
          Data Scientist & AI Engineer
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Grzegorz<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-emerald">
            Czopiński
          </span>
        </h1>
        <p class="text-gray-400 text-lg max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed">
          Buduję nowoczesne systemy danych i skalowalne aplikacje ETL w chmurze. 
          Zamieniam surowe dane w zautomatyzowane procesy decyzyjne, łącząc 
          inżynierię oprogramowania z najnowszymi modelami AI.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start flex-wrap">
          <a
            href="#projekty"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent hover:bg-accent-dark text-white font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-accent/25"
          >
            Zobacz projekty
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/grzegorz-czopi%C5%84ski-6878a133a/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-gray-700 hover:border-accent text-gray-300 hover:text-white font-semibold rounded-lg transition-all duration-300"
          >
            LinkedIn
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Avatar -->
      <div class="w-full lg:w-2/5 flex justify-center lg:justify-end">
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-accent to-emerald rounded-full blur-2xl opacity-30 scale-110"></div>
          <img
            src="/ds_ai_portfolio/avatar.png"
            alt="Grzegorz Czopiński"
            class="relative w-64 h-64 lg:w-80 lg:h-80 xl:w-96 xl:h-96 rounded-full object-cover border-4 border-accent/50 shadow-2xl"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </div>
</section>