---
import ProjectCard from './ProjectCard.astro';
import { projects } from '../data/projects';
---

<section id="projekty" class="py-20 bg-card/30">
  <div class="max-w-6xl mx-auto px-4">
    <div class="animate-on-scroll text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-2">Projekty</h2>
      <div class="w-20 h-1 bg-accent rounded mx-auto mb-4"></div>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Wybrane projekty demonstrujące umiejętności w zakresie Data Science, automatyzacji i tworzenia aplikacji.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </div>
</section>