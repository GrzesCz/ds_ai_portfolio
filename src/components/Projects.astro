---
import ProjectCard from './ProjectCard.astro';
import { projects, labProjects } from '../data/projects';
---

<section id="projekty" class="py-20 bg-card/30">
  <div class="max-w-6xl mx-auto px-4">
    <div class="animate-on-scroll text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-2">Projekty</h2>
      <div class="w-20 h-1 bg-accent rounded mx-auto mb-4"></div>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Wybrane projekty demonstrujące umiejętności w zakresie Data Science, automatyzacji i tworzenia aplikacji.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-20">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>

    <!-- Laboratorium / W warsztacie -->
    <div id="laboratorium" class="animate-on-scroll mb-8">
      <div class="flex items-center gap-3 mb-6 pt-16">
        <div class="w-10 h-10 rounded-lg bg-gray-800/80 flex items-center justify-center text-gray-300 text-xl border border-gray-700">🔬</div>
        <h3 class="text-2xl font-bold text-white">Laboratorium Innowacji</h3>
      </div>
      <p class="text-gray-400 mb-8 max-w-3xl">
        Projekty, nad którymi aktualnie pracuję w ramach samorozwoju, testowania nowych technologii lub tworzenia dowodów słuszności koncepcji (Proof of Concept).
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {labProjects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </div>
  </div>
</section>