---
const achievements = [
  {
    number: '12',
    unit: 'lat',
    label: 'doświadczenia w analizie danych',
    icon: '📊',
  },
  {
    number: '15+',
    unit: '',
    label: 'dashboardów Power BI',
    icon: '📈',
  },
  {
    number: '80%',
    unit: '',
    label: 'redukcja czasu raportowania',
    icon: '⚡',
  },
  {
    number: '1',
    unit: '',
    label: 'system produkcyjny (KOPI)',
    icon: '🚀',
  },
];
---

<section id="osiagniecia" class="py-20 bg-card/30">
  <div class="max-w-6xl mx-auto px-4">
    <div class="animate-on-scroll text-center mb-12">
      <h2 class="text-3xl font-bold text-white mb-2">Kluczowe osiągnięcia</h2>
      <div class="w-20 h-1 bg-accent rounded mx-auto mb-4"></div>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Mierzalne rezultaty, które potwierdzają realne umiejętności w analizie danych i automatyzacji.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {achievements.map((a, i) => (
        <div
          class="animate-on-scroll bg-card border border-gray-800 rounded-xl p-6 text-center hover:border-accent/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent/5"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="text-4xl mb-3">{a.icon}</div>
          <div class="text-4xl lg:text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-light">
            {a.number}<span class="text-2xl">{a.unit}</span>
          </div>
          <p class="text-gray-400 mt-2 text-sm">{a.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>