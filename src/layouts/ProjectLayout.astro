---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={`${title} | Grzegorz Czopiński`} description={description}>
  <Navbar />
  <main class="pt-20">
    <slot />
  </main>

  <footer class="border-t border-gray-800 py-8 text-center text-gray-500 text-sm">
    <div class="max-w-6xl mx-auto px-4">
      <p>&copy; {new Date().getFullYear()} Grzegorz Czopiński. Wszystkie prawa zastrzeżone.</p>
    </div>
  </footer>
</BaseLayout>